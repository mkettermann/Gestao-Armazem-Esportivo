{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identidade-route": {
        "ClusterId": "identidade-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "catalogo-route": {
        "ClusterId": "catalogo-cluster",
        "Match": {
          "Path": "/produtos/{**catch-all}"
        }
      },
      "estoque-route": {
        "ClusterId": "estoque-cluster",
        "Match": {
          "Path": "/estoque/{**catch-all}"
        }
      },
      "pedidos-route": {
        "ClusterId": "pedidos-cluster",
        "Match": {
          "Path": "/pedidos/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identidade-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://identidade-api:8080"
          }
        }
      },
      "catalogo-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://catalogo-api:8080"
          }
        }
      },
      "estoque-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://estoque-api:8080"
          }
        }
      },
      "pedidos-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://pedidos-api:8080"
          }
        }
      }
    }
  }
}