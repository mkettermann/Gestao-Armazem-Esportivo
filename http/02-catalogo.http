### Variáveis globais
@baseUrl = http://localhost:8080
@contentType = application/json
# Cole aqui o token obtido em 01-autenticacao.http (login Admin)
@tokenAdmin = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..4TQHfAXWtUDsJ1w-na0kdR4fPg8WZ-UC-2GNFNI9BsA
@tokenVendedor = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..A4xJuVp2Lfd1H1przXiiif3s-GNsq1qAaxeOKGxD6Y4

# -------------------------------------------------------------------
# CATÁLOGO DE PRODUTOS
# -------------------------------------------------------------------

### Criar produto (requer role Administrador)
# @name criarProduto
POST {{baseUrl}}/produtos
Content-Type: {{contentType}}
Authorization: Bearer {{tokenAdmin}}

{
  "nome": "Bola de Futebol Society",
  "descricao": "Bola oficial tamanho 5, costura dupla",
  "preco": 89.90
}

###

### Listar produtos (paginação) - roles: Administrador, Vendedor
GET {{baseUrl}}/produtos?pagina=1&tamanhoPagina=20
Authorization: Bearer {{tokenVendedor}}

###

### Obter produto por ID - roles: Administrador, Vendedor
# Substitua o GUID pelo id retornado em "Criar produto"
GET {{baseUrl}}/produtos/2b2eaa3f-bcf4-4247-8ed4-755dc17f22eb
Authorization: Bearer {{tokenVendedor}}

###

### Atualizar produto (requer role Administrador)
# Substitua o GUID pelo id do produto
PUT {{baseUrl}}/produtos/2b2eaa3f-bcf4-4247-8ed4-755dc17f22eb
Content-Type: {{contentType}}
Authorization: Bearer {{tokenAdmin}}

{
  "nome": "Bola de Futebol Society Pro",
  "descricao": "Bola oficial tamanho 5, costura tripla reforçada",
  "preco": 129.90
}

###

### Remover produto (requer role Administrador)
# Substitua o GUID pelo id do produto
DELETE {{baseUrl}}/produtos/2b2eaa3f-bcf4-4247-8ed4-755dc17f22eb
Authorization: Bearer {{tokenAdmin}}
