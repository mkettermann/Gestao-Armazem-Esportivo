@tokenAdmin = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..Ztd2Ce24ts0krhzWTBV9-RJN4suYIcAIQFc-oU187B8
@tokenVendedor = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..QjxCx7topUSKRAkeEDpgp8B3FCF2KXnEMe0wToBD1VU

# -------------------------------------------------------------------
# ESTOQUE
# -------------------------------------------------------------------

### Consultar estoque de um produto - roles: Administrador, Vendedor
# Substitua o GUID pelo id do produto
GET {{baseUrl}}/estoque/d5ad5d3e-578b-40ae-85e6-ca347755071c
Authorization: Bearer {{tokenVendedor}}

###

### Adicionar estoque para um produto (requer role Administrador)
# Substitua o GUID pelo id do produto cadastrado no catálogo
POST {{baseUrl}}/estoque/d5ad5d3e-578b-40ae-85e6-ca347755071c/entradas
Content-Type: {{contentType}}
Authorization: Bearer {{tokenAdmin}}

{
  "quantidade": 50,
  "numeroNotaFiscal": "NF-2026-0001"
}
