### Variáveis globais
@baseUrl = http://localhost:8080
@contentType = application/json
# Cole aqui os tokens obtidos em 01-autenticacao.http
@tokenAdmin = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..EP1zMoZ3dH_yJribNzRna7b0bL_sMBkT6b5i48wd7Sg
@tokenVendedor = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..99c3go38FLlIpdl_eEEc4NbAezDhkJM-cYTwVbmmdXM

# -------------------------------------------------------------------
# PEDIDOS
# -------------------------------------------------------------------

### Emitir pedido (requer role Vendedor)
# @name emitirPedido
# Substitua os GUIDs pelos ids reais dos produtos
POST {{baseUrl}}/pedidos
Content-Type: {{contentType}}
Authorization: Bearer {{tokenVendedor}}

{
  "documentoCliente": "123.456.789-00",
  "nomeVendedor": "Vendedor Teste",
  "itens": [
    {
      "produtoId": "bbdacfe0-a2de-458b-9db9-4124501e4086",
      "quantidade": 2
    }
  ]
}

###

### Obter pedido por ID - roles: Administrador, Vendedor
# Substitua o GUID pelo id retornado em "Emitir pedido"
GET {{baseUrl}}/pedidos/bbdacfe0-a2de-458b-9db9-4124501e4086
Authorization: Bearer {{tokenAdmin}}
